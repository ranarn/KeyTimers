<Window x:Class="KeyTimers.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KeyTimers.Views"
        xmlns:models="clr-namespace:KeyTimers.Models"
        Title="KeyTimers — Settings"
        Width="600" Height="660"
        MinWidth="520" MinHeight="540"
        Background="#1E1E2E"
        Foreground="White"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <local:HexColorConverter x:Key="HexColor"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Labels -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Text inputs -->
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- ComboBox — full ControlTemplate required to dark-theme the popup background -->
        <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="#45475A" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1" BorderBrush="#45475A" BorderThickness="1,0,0,0">
                        <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M0,0 L4,4 L8,0 Z" Fill="#CDD6F4"/>
                    </Border>
                </Grid>
            </Border>
        </ControlTemplate>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#313244"/>
                        <Setter Property="Foreground" Value="#CDD6F4"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="#45475A"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#585B70"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Selected-item display + toggle button -->
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboToggle}"
                                          Background="{TemplateBinding Background}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="8,4,24,4"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"/>
                            <!-- Dark popup -->
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDown"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#252535"
                                        BorderBrush="#45475A"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Buttons -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#585B70"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B4D0FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#F38BA8"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>
        <Style x:Key="BtnPick" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="ToolTip" Value="Pick colour"/>
        </Style>

        <ObjectDataProvider x:Key="CountDirections" MethodName="GetValues" ObjectType="{x:Type models:CountDirection}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:CountDirection"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="ClickBehaviours" MethodName="GetValues" ObjectType="{x:Type models:ClickBehaviour}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ClickBehaviour"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="AlertTypes" MethodName="GetValues" ObjectType="{x:Type models:AlertType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:AlertType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Section: Overlay Appearance ─────────────────────────────── -->
        <TextBlock Grid.Row="0" Text="OVERLAY APPEARANCE"
                   Foreground="#89B4FA" FontSize="11" FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Background colour | Opacity -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Background colour" Style="{StaticResource Label}"/>
            <DockPanel Grid.Row="0" Grid.Column="2">
                <Button DockPanel.Dock="Right" Style="{StaticResource BtnPick}"
                        Content="⬛" Margin="4,0,0,0"
                        Click="PickBgColor_Click"/>
                <Border DockPanel.Dock="Right" Width="22" Margin="4,0,0,0"
                        Background="{Binding Settings.BackgroundColor, Converter={StaticResource HexColor}}"
                        CornerRadius="2" BorderBrush="#45475A" BorderThickness="1"/>
                <TextBox Style="{StaticResource Input}"
                         Text="{Binding Settings.BackgroundColor, UpdateSourceTrigger=PropertyChanged}"/>
            </DockPanel>

            <TextBlock Grid.Row="0" Grid.Column="4" Text="Opacity (0.1–1.0)" Style="{StaticResource Label}"/>
            <TextBox   Grid.Row="0" Grid.Column="6" Style="{StaticResource Input}"
                       Text="{Binding Settings.OverlayOpacity, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"/>

            <!-- Row 2: Font family | Font size -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Font family" Style="{StaticResource Label}"/>
            <TextBox   Grid.Row="2" Grid.Column="2" Style="{StaticResource Input}"
                       Text="{Binding Settings.FontFamily, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Grid.Column="4" Text="Font size" Style="{StaticResource Label}"/>
            <TextBox   Grid.Row="2" Grid.Column="6" Style="{StaticResource Input}"
                       Text="{Binding Settings.FontSize, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Row 4: Show key label -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Show key label" Style="{StaticResource Label}"/>
            <CheckBox  Grid.Row="4" Grid.Column="2"
                       IsChecked="{Binding Settings.ShowKeyLabel}"
                       Foreground="#CDD6F4" VerticalAlignment="Center"/>

            <!-- Row 6: Pause key | Pause colour -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Pause key" Style="{StaticResource Label}"
                       ToolTip="Key that pauses / resumes all timers globally (e.g. F9). Leave empty to disable."/>
            <local:KeyCaptureTextBox Grid.Row="6" Grid.Column="2" Style="{StaticResource Input}"
                       Text="{Binding Settings.PauseKey, Mode=TwoWay}"/>

            <TextBlock Grid.Row="6" Grid.Column="4" Text="Pause colour" Style="{StaticResource Label}"/>
            <DockPanel Grid.Row="6" Grid.Column="6">
                <Button DockPanel.Dock="Right" Style="{StaticResource BtnPick}"
                        Content="⬛" Margin="4,0,0,0"
                        Click="PickPauseColor_Click"/>
                <Border DockPanel.Dock="Right" Width="22" Margin="4,0,0,0"
                        Background="{Binding Settings.PauseColor, Converter={StaticResource HexColor}}"
                        CornerRadius="2" BorderBrush="#45475A" BorderThickness="1"/>
                <TextBox Style="{StaticResource Input}"
                         Text="{Binding Settings.PauseColor, UpdateSourceTrigger=PropertyChanged}"/>
            </DockPanel>

            <!-- Row 8: Timer border thickness | Timer border colour -->
            <TextBlock Grid.Row="8" Grid.Column="0" Text="Timer border px" Style="{StaticResource Label}"
                       ToolTip="Border thickness in pixels around each timer row. 0 = no border."/>
            <TextBox   Grid.Row="8" Grid.Column="2" Style="{StaticResource Input}"
                       Text="{Binding Settings.TimerBorderThickness, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="8" Grid.Column="4" Text="Timer border colour" Style="{StaticResource Label}"/>
            <DockPanel Grid.Row="8" Grid.Column="6">
                <Button DockPanel.Dock="Right" Style="{StaticResource BtnPick}"
                        Content="⬛" Margin="4,0,0,0"
                        Click="PickBorderColor_Click"/>
                <Border DockPanel.Dock="Right" Width="22" Margin="4,0,0,0"
                        Background="{Binding Settings.TimerBorderColor, Converter={StaticResource HexColor}}"
                        CornerRadius="2" BorderBrush="#45475A" BorderThickness="1"/>
                <TextBox Style="{StaticResource Input}"
                         Text="{Binding Settings.TimerBorderColor, UpdateSourceTrigger=PropertyChanged}"/>
            </DockPanel>

            <!-- Row 10: Show decimal -->
            <TextBlock Grid.Row="10" Grid.Column="0" Text="Show decimal" Style="{StaticResource Label}"
                       ToolTip="Show one decimal digit on the timer (e.g. 90.3). Uncheck for whole seconds (90)."/>
            <CheckBox  Grid.Row="10" Grid.Column="2"
                       IsChecked="{Binding Settings.ShowDecimal}"
                       Foreground="#CDD6F4" VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Section: Timers ──────────────────────────────────────────── -->
        <TextBlock Grid.Row="4" Text="TIMERS" Foreground="#89B4FA"
                   FontSize="11" FontWeight="Bold"
                   VerticalAlignment="Top" Margin="0,0,0,8"/>

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Margin="0,22,0,0">
            <ItemsControl x:Name="TimerList" ItemsSource="{Binding Settings.Timers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:TimerConfig}">
                        <Border Margin="0,0,0,8" Padding="10,8"
                                Background="#313244" CornerRadius="4"
                                BorderBrush="#45475A" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Key + Label + Duration + Enabled -->
                                <Grid Grid.Row="0" Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Key" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                        <local:KeyCaptureTextBox Style="{StaticResource Input}"
                                                 Text="{Binding Key, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Label" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                        <TextBox Style="{StaticResource Input}"
                                                 Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Seconds" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                        <TextBox Style="{StaticResource Input}"
                                                 Text="{Binding DurationSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="Enabled" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                        <CheckBox IsChecked="{Binding Enabled}"
                                                  Foreground="#CDD6F4" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 2: Direction + On re-press + Alert type + Auto-resend -->
                                <Grid Grid.Row="2" Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Direction" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                        <ComboBox Style="{StaticResource ComboStyle}"
                                                  ItemsSource="{Binding Source={StaticResource CountDirections}}"
                                                  SelectedItem="{Binding Direction}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="On re-press" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                        <ComboBox Style="{StaticResource ComboStyle}"
                                                  ItemsSource="{Binding Source={StaticResource ClickBehaviours}}"
                                                  SelectedItem="{Binding ClickBehaviour}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Alert type" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                        <ComboBox Style="{StaticResource ComboStyle}"
                                                  ItemsSource="{Binding Source={StaticResource AlertTypes}}"
                                                  SelectedItem="{Binding AlertType}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                                        <TextBlock Text="Auto-trigger" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                        <CheckBox IsChecked="{Binding AutoResendOnComplete}"
                                                  Foreground="#CDD6F4" VerticalAlignment="Center"
                                                  ToolTip="When the timer completes, automatically send the bound key to the active window and restart the timer"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 4: Normal colour + Alert colour + Sound file -->
                                <Grid Grid.Row="4" Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Normal colour -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Normal colour" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource BtnPick}"
                                                    Content="⬛" Margin="3,0,0,0"
                                                    Tag="{Binding}" CommandParameter="NormalColor"
                                                    Click="PickTimerColor_Click"/>
                                            <Border DockPanel.Dock="Right" Width="22" Margin="3,0,0,0"
                                                    Background="{Binding NormalColor, Converter={StaticResource HexColor}}"
                                                    CornerRadius="2" BorderBrush="#45475A" BorderThickness="1"/>
                                            <TextBox Style="{StaticResource Input}"
                                                     Text="{Binding NormalColor, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DockPanel>
                                    </StackPanel>

                                    <!-- Alert colour -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Alert colour" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource BtnPick}"
                                                    Content="⬛" Margin="3,0,0,0"
                                                    Tag="{Binding}" CommandParameter="AlertColor"
                                                    Click="PickTimerColor_Click"/>
                                            <Border DockPanel.Dock="Right" Width="22" Margin="3,0,0,0"
                                                    Background="{Binding AlertColor, Converter={StaticResource HexColor}}"
                                                    CornerRadius="2" BorderBrush="#45475A" BorderThickness="1"/>
                                            <TextBox Style="{StaticResource Input}"
                                                     Text="{Binding AlertColor, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DockPanel>
                                    </StackPanel>

                                    <!-- Sound file -->
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Sound file (wav/mp3)" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                        <TextBox Style="{StaticResource Input}"
                                                 Text="{Binding SoundFilePath, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <Button Grid.Column="6" Content="…" Style="{StaticResource Btn}"
                                            VerticalAlignment="Bottom" Margin="4,0,0,0"
                                            Tag="{Binding}"
                                            Click="BrowseSoundFile_Click"/>
                                </Grid>

                                <!-- Row 6: Auto-trigger delay range -->
                                <Grid Grid.Row="6" Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Trigger min delay (s)" Style="{StaticResource Label}" Margin="0,0,0,2"
                                                   ToolTip="Minimum random delay before auto-trigger fires (0 = immediate)"/>
                                        <TextBox Style="{StaticResource Input}"
                                                 Text="{Binding AutoTriggerMinDelay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Trigger max delay (s)" Style="{StaticResource Label}" Margin="0,0,0,2"
                                                   ToolTip="Maximum random delay before auto-trigger fires"/>
                                        <TextBox Style="{StaticResource Input}"
                                                 Text="{Binding AutoTriggerMaxDelay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Delete button -->
                                <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="7"
                                        Content="✕" Style="{StaticResource BtnDanger}"
                                        VerticalAlignment="Top" Margin="8,0,0,0"
                                        Tag="{Binding}"
                                        Click="DeleteTimer_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Add timer button ─────────────────────────────────────────── -->
        <Button Grid.Row="6" Content="+ Add Timer" Style="{StaticResource Btn}"
                HorizontalAlignment="Left" Click="AddTimer_Click"/>

        <!-- ── Save / Save and Exit / Cancel ───────────────────────────── -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource Btn}"
                    Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save" Style="{StaticResource Btn}"
                    Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Save and Exit" Style="{StaticResource BtnAccent}"
                    Click="SaveAndExit_Click"/>
        </StackPanel>
    </Grid>
</Window>
